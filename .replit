modules = ["nodejs-24", "python-3.11", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true
integrations = ["stripe:1.0.0"]

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 8082
externalPort = 3003

[[ports]]
localPort = 25638
externalPort = 3000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
ADMIN_EMAIL = "maxsantosmotta@gmail.com"
GLOBAL_BETA_MODE = "true"
VITE_GLOBAL_BETA_MODE = "true"
HEYGEN_AVATAR_MALE_ID = "d08c85e6cff84d78b6dc41d83a2eccce"
HEYGEN_AVATAR_FEMALE_ID = "977b1ab85dba4eefb159a6072677effd"
HEYGEN_VOICE_MALE_ID = "0d0e23e8170446e38b18a7380b2d30a8"
HEYGEN_VOICE_FEMALE_ID = "0edbc867be6f48c5be8ff8b0fbca0802"

[userenv.production]
APP_PUBLIC_URL = "https://iattomassist.com.br"
